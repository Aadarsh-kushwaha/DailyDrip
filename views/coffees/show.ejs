<% layout('layouts/boilerplate') %>


<div class="coffee-container d-flex justify-content-center align-items-center" 
     style="min-height: 100vh; background: linear-gradient(to right, #f3e5d8, #e6d3c3);">

  <div class="card shadow-lg border-4" 
       style="max-width: 650px; border-radius: 15px; background-color: #fffaf5;">

    <div class="row g-0">

      <!-- Image -->
      <div class="col-md-4 border">
        <img src="<%= product.image %>" 
             class="img-fluid h-100 w-100" 
             style="object-fit: cover; border-top-left-radius: 15px; border-bottom-left-radius: 15px;" 
             alt="<%= product.name %>">
      </div>

      <!-- Content -->
      <div class="col-md-8">
        <div class="card-body d-flex flex-column justify-content-center">

          <h4 class="card-title fw-bold" style="color: #4b2e2e;">
            <%= product.name %>
          </h4>

          <p class="card-text" style="color: #6b4f4f;">
            <%= product.description %>
          </p>

          <p class="fw-semibold" style="color: #8b4513;">
            ₹ <%= product.price %>
          </p>

          <p class="mb-2">
            ⭐ <%= product.avgRating %> / 5
          </p>

          <!-- 🔥 Category Tag -->
          <span class="badge mb-2" 
                style="background-color: <%= product.category === 'coffee' ? '#6f4e37' : '#17a2b8' %>;">
            <%= product.category.toUpperCase() %>
          </span>

          <!-- 🔥 Add to Cart Button -->
          <form action="/cart/<%= product._id %>" method="POST">
            <button class="btn mt-2" 
                    style="background-color: #6f4e37; color: white; border-radius: 8px;">
              Add to Cart
            </button>
          </form>

          <!-- Back -->
          <a href="/menu" class="btn mt-2" 
             style="border: 1px solid #6f4e37; color: #6f4e37; border-radius: 8px;">
            Back
          </a>

        </div>
      </div>

    </div>

  </div>

</div>
